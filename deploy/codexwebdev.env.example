HOST=127.0.0.1
PORT=3060
NODE_ENV=production

# Required secrets
SESSION_SECRET=replace-with-long-random-secret
CREDENTIALS_ENCRYPTION_KEY=replace-with-strong-random-key

# Keep codexwebdev isolated from codexweb production data/state
DB_PATH=.runtime/dev/app.dev.db
UPLOADS_DIR=.runtime/dev/uploads
TASK_SNAPSHOTS_DIR=.runtime/dev/tmp/task-snapshots
TASK_SNAPSHOT_MAX_FILES=900
TASK_SNAPSHOT_MAX_FILE_BYTES=8388608
TASK_SNAPSHOT_MAX_TOTAL_BYTES=67108864
TASK_SNAPSHOTS_RETENTION_MAX_BYTES=536870912
TASK_SNAPSHOTS_RETENTION_MAX_ENTRIES=10
TASK_SNAPSHOTS_RETENTION_MAX_AGE_HOURS=12
TASK_SNAPSHOTS_PRUNE_INTERVAL_MINUTES=20
STORAGE_JOBS_DIR=.runtime/dev/tmp/storage-jobs
RESTART_STATE_PATH=.runtime/dev/restart-state.dev.json
STATIC_ASSETS_DIR=public
CODEX_HOME_ROOT=/var/lib/codexweb/codex_users_dev
RCLONE_BIN=rclone
RCLONE_CONFIG_PATH=/root/.config/rclone/rclone.conf
RCLONE_DRIVE_DEFAULT_REMOTE=codexwebdev-gdrive
RCLONE_DRIVE_DEFAULT_ROOT=CodexWebDEV
STORAGE_RESIDUAL_SCAN_ROOTS=/root/CodexWeb/.runtime/dev/tmp,/root/CodexWeb/.runtime/dev/uploads,/tmp,/var/tmp

# AI/tool runtime settings
CODEX_CMD=codex
GEMINI_CMD=gemini
GEMINI_INCLUDE_DIRECTORIES=/
GIT_TOOLS_SCAN_ROOTS=/root/CodexWeb,/opt
