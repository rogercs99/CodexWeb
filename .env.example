HOST=127.0.0.1
PORT=3050
SESSION_SECRET=pon-un-secreto-largo-de-sesion
OPENAI_API_KEY=
CODEX_CMD=codex
GEMINI_CMD=gemini
GEMINI_INCLUDE_DIRECTORIES=/
NODE_ENV=development
GIT_TOOLS_SCAN_ROOTS=/root/CodexWeb,/opt
RCLONE_BIN=rclone
RCLONE_CONFIG_PATH=/root/.config/rclone/rclone.conf
RCLONE_DRIVE_DEFAULT_REMOTE=codexwebdev-gdrive
RCLONE_DRIVE_DEFAULT_ROOT=CodexWebDEV
STORAGE_RESIDUAL_SCAN_ROOTS=/root/CodexWeb/.runtime/dev/tmp,/root/CodexWeb/.runtime/dev/uploads,/tmp,/var/tmp

# Optional path overrides (useful to isolate codexwebdev from codexweb prod)
DB_PATH=app.db
UPLOADS_DIR=uploads
TASK_SNAPSHOTS_DIR=tmp/task-snapshots
STORAGE_JOBS_DIR=tmp/storage-jobs
RESTART_STATE_PATH=restart-state.json
STATIC_ASSETS_DIR=public
